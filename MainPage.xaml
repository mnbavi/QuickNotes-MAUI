<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuickNotesApp.MainPage"
             BackgroundColor="#FDFDFD">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Mis Notas Rápidas" 
               FontSize="28" FontAttributes="Bold" 
               TextColor="#512BD4" HorizontalOptions="Center" Margin="0,10" />

        <Frame BorderColor="#512BD4" CornerRadius="10" Padding="5">
            <Editor x:Name="NotaEditor" 
                    Placeholder="Escribe algo importante aquí..." 
                    HeightRequest="100" />
        </Frame>

        <Button Text="GUARDAR NOTA" 
                Clicked="OnGuardarClicked"
                BackgroundColor="#512BD4" TextColor="White" 
                CornerRadius="20" HeightRequest="50" />

        <BoxView HeightRequest="1" Color="#EEEEEE" />

        <CollectionView x:Name="ListaNotas">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10" BorderColor="#DDD">
                        <Label Text="{Binding .}" FontSize="16" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>